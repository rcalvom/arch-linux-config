- Para instalar steam tuve que hacer lo siguiente,
-- Activar multilib en /etc/pacman.conf
-- Descomentar [multilib]
Include = /etc/pacman.d/mirrorlis
-- Instalar vulcan sudo pacman -S --needed vulkan-tools vulkan-icd-loader lib32-vulkan-icd-loader
-- instalar los drivers sudo pacman -S --needed mesa vulkan-radeon lib32-vulkan-radeon
