#!/usr/bin/env python3
"""Cache Waybar workspace state once per Hyprland event."""

from __future__ import annotations

import json
import os
import subprocess
import sys
from pathlib import Path


WORKSPACES = {
    1: ("", "Console"),
    2: ("󰚩", "Agents"),
    3: ("", "Firefox"),
    4: ("", "Development"),
    5: ("", "File Explorer"),
    6: ("󰇮", "Mail"),
    7: ("󰵅", "Messages"),
    8: ("", "Entertainment"),
    9: ("󰍻", "Others"),
}
CACHE_NAME = "archcfg-hypr-workspaces"


def cache_path() -> Path | None:
    runtime_dir = os.environ.get("XDG_RUNTIME_DIR")
    return Path(runtime_dir, CACHE_NAME) if runtime_dir else None


def hyprctl_json(command: str) -> list[dict[str, object]]:
    result = subprocess.run(
        ["hyprctl", "-j", command],
        check=True,
        capture_output=True,
        text=True,
    )
    return json.loads(result.stdout)


def workspace_state() -> dict[str, dict[str, str]]:
    try:
        monitors = hyprctl_json("monitors")
        workspaces = hyprctl_json("workspaces")
    except (OSError, subprocess.CalledProcessError, json.JSONDecodeError):
        monitors = []
        workspaces = []

    focused = next((monitor for monitor in monitors if monitor.get("focused")), None)
    visible = {
        monitor.get("activeWorkspace", {}).get("id")
        for monitor in monitors
    }
    occupied = {
        workspace.get("id")
        for workspace in workspaces
        if workspace.get("windows", 0) > 0
    }
    state: dict[str, dict[str, str]] = {}

    for workspace_id, (icon, name) in WORKSPACES.items():
        if focused and focused.get("activeWorkspace", {}).get("id") == workspace_id:
            css_class = "active"
        elif workspace_id in visible:
            css_class = "visible"
        elif workspace_id in occupied:
            css_class = "occupied"
        else:
            css_class = "inactive"

        trailing_space = "" if workspace_id == 1 else "\u2009"
        state[str(workspace_id)] = {
            "text": icon + trailing_space,
            "tooltip": name,
            "class": css_class,
        }

    return state


def main() -> int:
    if sys.argv[1:]:
        return 2

    path = cache_path()
    if path is None:
        return 1

    temporary = path.with_name(f".{path.name}.{os.getpid()}")
    with temporary.open("w", encoding="utf-8") as cache:
        for workspace_id, payload in workspace_state().items():
            cache.write(f"{workspace_id}\t{json.dumps(payload, ensure_ascii=False)}\n")
    temporary.replace(path)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
