#!/usr/bin/env python3
"""Start Waybar only after the compositor and its outputs are ready."""

from __future__ import annotations

import json
import os
import stat
import subprocess
import sys
import time


def ready() -> bool:
    runtime_dir = os.environ.get("XDG_RUNTIME_DIR")
    display = os.environ.get("WAYLAND_DISPLAY")
    if not runtime_dir:
        return False

    if not display:
        try:
            display = next(
                entry.name
                for entry in os.scandir(runtime_dir)
                if entry.name.startswith("wayland-")
                and stat.S_ISSOCK(entry.stat().st_mode)
            )
            os.environ["WAYLAND_DISPLAY"] = display
        except (FileNotFoundError, StopIteration):
            return False

    try:
        if not stat.S_ISSOCK(os.stat(os.path.join(runtime_dir, display)).st_mode):
            return False
        result = subprocess.run(
            ["hyprctl", "-j", "monitors"],
            check=True,
            capture_output=True,
            text=True,
        )
        return any(not monitor.get("disabled", False) for monitor in json.loads(result.stdout))
    except (OSError, subprocess.CalledProcessError, json.JSONDecodeError):
        return False


def main() -> None:
    while not ready():
        # Yield until compositor state changes instead of using a fixed startup delay.
        time.sleep(0.05)
    subprocess.run(
        [sys.executable, os.path.join(os.path.dirname(os.path.abspath(__file__)), "hypr-workspace-state")],
        check=False,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )
    os.execvp("waybar", ["waybar"])


if __name__ == "__main__":
    main()
