#!/usr/bin/env bash
set -euo pipefail

REPO_DIR="/opt/arch-linux-config"

if [[ ! -f "$REPO_DIR/install.sh" ]]; then
  printf '[ERROR] Installer not found at %s/install.sh\n' "$REPO_DIR" >&2
  exit 1
fi

cd "$REPO_DIR"

if [[ "${EUID:-$(id -u)}" -ne 0 ]]; then
  exec sudo bash ./install.sh "$@"
fi

exec bash ./install.sh "$@"
