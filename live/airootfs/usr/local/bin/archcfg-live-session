#!/usr/bin/env bash
set -euo pipefail

REPO_DIR="/opt/arch-linux-config"
LIVE_USER="${USER:-live}"
LIVE_HOME="${HOME:-/home/live}"

log_info() {
  printf '[INFO] %s\n' "$*"
}

log_warn() {
  printf '[WARN] %s\n' "$*" >&2
}

install_live_file() {
  local src=$1
  local dest=$2
  local mode=$3

  [[ -f "$src" ]] || return 0
  install -Dm"$mode" "$src" "$dest"
}

install_live_tree() {
  local src_dir=$1
  local dest_dir=$2
  local mode=$3
  local file
  local relative

  [[ -d "$src_dir" ]] || return 0
  src_dir=$(cd -- "$src_dir" && pwd -P)

  while IFS= read -r -d '' file; do
    [[ "$(basename -- "$file")" == "files.conf" ]] && continue
    relative=${file#"$src_dir"/}
    install -Dm"$mode" "$file" "$dest_dir/$relative"
  done < <(find "$src_dir" -type f -print0)
}

apply_live_package_config_manifest() {
  local manifest=$1
  local package_dir
  local kind
  local mode
  local source
  local destination

  package_dir=$(cd -- "$(dirname -- "$manifest")" && pwd -P)

  while IFS='|' read -r kind mode source destination || [[ -n "$kind" ]]; do
    [[ -z "$kind" || "$kind" == \#* ]] && continue
    [[ -n "$mode" && -n "$source" && -n "$destination" ]] || return 1

    case "$kind" in
      user_file)
        install_live_file "$package_dir/$source" "$LIVE_HOME/$destination" "$mode"
        ;;
      user_tree)
        install_live_tree "$package_dir/$source" "$LIVE_HOME/$destination" "$mode"
        ;;
    esac
  done < "$manifest"
}

install_live_package_configs() {
  local manifests=("$REPO_DIR"/packages/*/files.conf)
  local manifest

  [[ -e "${manifests[0]}" ]] || return 0

  for manifest in "${manifests[@]}"; do
    apply_live_package_config_manifest "$manifest"
  done
}

initialize_live_browser_profile() {
  local launcher=$1

  [[ -x "$launcher" ]] || return 0
  HOME="$LIVE_HOME" XDG_CONFIG_HOME="$LIVE_HOME/.config" "$launcher" --version >/dev/null 2>&1 || \
    log_warn "Unable to initialize browser profile with $launcher"
}

chown_live_path() {
  local path=$1

  [[ -e "$path" ]] || return 0
  chown -R "$LIVE_USER:$LIVE_USER" "$path"
}

create_xdg_user_dirs() {
  if command -v xdg-user-dirs-update >/dev/null 2>&1; then
    HOME="$LIVE_HOME" XDG_CONFIG_HOME="$LIVE_HOME/.config" xdg-user-dirs-update
  fi
}

install_live_configs() {
  local unit
  local hypr_config="$LIVE_HOME/.config/hypr/hyprland.lua"

  install_live_file "$REPO_DIR/wayland/hypr/hyprland.lua" "$hypr_config" 0644
  install_live_file "$REPO_DIR/wayland/hypr/hyprtoolkit.conf" "$LIVE_HOME/.config/hypr/hyprtoolkit.conf" 0644
  install_live_file "$REPO_DIR/wayland/hypr/hyprlock.conf" "$LIVE_HOME/.config/hypr/hyprlock.conf" 0644
  install_live_file "$REPO_DIR/wayland/hypr/hyprpaper.conf" "$LIVE_HOME/.config/hypr/hyprpaper.conf" 0644
  install_live_file "$REPO_DIR/wayland/wallpapers/wallpaper.png" "$LIVE_HOME/Pictures/wallpaper2.png" 0644
  install_live_file "$REPO_DIR/wayland/waybar/config.jsonc" "$LIVE_HOME/.config/waybar/config.jsonc" 0644
  install_live_file "$REPO_DIR/wayland/waybar/style.css" "$LIVE_HOME/.config/waybar/style.css" 0644
  install_live_file "$REPO_DIR/wayland/rofi/config.rasi" "$LIVE_HOME/.config/rofi/config.rasi" 0644
  install_live_file "$REPO_DIR/wayland/rofi/share-picker.rasi" "$LIVE_HOME/.config/rofi/share-picker.rasi" 0644
  install_live_file "$REPO_DIR/wayland/mimeapps.list" "$LIVE_HOME/.config/mimeapps.list" 0644
  install_live_file "$REPO_DIR/wayland/mako/config" "$LIVE_HOME/.config/mako/config" 0644
  install_live_file "$REPO_DIR/wayland/fontconfig/conf.d/99-ubuntu-fallback.conf" "$LIVE_HOME/.config/fontconfig/conf.d/99-ubuntu-fallback.conf" 0644
  install_live_package_configs
  initialize_live_browser_profile "$LIVE_HOME/.local/bin/archcfg-firefox"
  initialize_live_browser_profile "$LIVE_HOME/.local/bin/archcfg-thunderbird"
  install_live_file "$REPO_DIR/wayland/bin/hyprsunset-set" "$LIVE_HOME/.local/bin/hyprsunset-set" 0755
  install_live_file "$REPO_DIR/wayland/bin/hyprsunset-apply-current" "$LIVE_HOME/.local/bin/hyprsunset-apply-current" 0755
  install_live_file "$REPO_DIR/wayland/bin/hypr-audio-selector" "$LIVE_HOME/.local/bin/hypr-audio-selector" 0755
  install_live_file "$REPO_DIR/wayland/bin/hypr-display-layout" "$LIVE_HOME/.local/bin/hypr-display-layout" 0755
  install_live_file "$REPO_DIR/wayland/bin/hypr-display-menu" "$LIVE_HOME/.local/bin/hypr-display-menu" 0755
  install_live_file "$REPO_DIR/wayland/bin/hypr-layout-cycle" "$LIVE_HOME/.local/bin/hypr-layout-cycle" 0755
  install_live_file "$REPO_DIR/wayland/bin/hypr-layout-name" "$LIVE_HOME/.local/bin/hypr-layout-name" 0755
  install_live_file "$REPO_DIR/wayland/bin/hypr-workspace-swap" "$LIVE_HOME/.local/bin/hypr-workspace-swap" 0755
  install_live_file "$REPO_DIR/wayland/bin/hypr-workspace-status" "$LIVE_HOME/.local/bin/hypr-workspace-status" 0755
  install_live_file "$REPO_DIR/wayland/bin/hypr-workspace-state" "$LIVE_HOME/.local/bin/hypr-workspace-state" 0755
  install_live_file "$REPO_DIR/wayland/bin/hypr-workspace-watch" "$LIVE_HOME/.local/bin/hypr-workspace-watch" 0755
  install_live_file "$REPO_DIR/wayland/bin/hypr-waybar-start" "$LIVE_HOME/.local/bin/hypr-waybar-start" 0755

  for unit in hyprsunset-day.service hyprsunset-day.timer hyprsunset-night.service hyprsunset-night.timer; do
    install_live_file "$REPO_DIR/wayland/systemd/user/$unit" "$LIVE_HOME/.config/systemd/user/$unit" 0644
  done

  if [[ -f "$hypr_config" ]] && ! grep -q 'Arch Config Live terminal' "$hypr_config"; then
    cat >> "$hypr_config" <<'HYPRLIVE'

-- Arch Config Live terminal
hl.on("hyprland.start", function()
  hl.exec_cmd("alacritty -e zsh -lc 'cat /etc/motd; exec zsh -i'")
end)
HYPRLIVE
  fi

  create_xdg_user_dirs
  chown_live_path "$LIVE_HOME/.config"
  chown_live_path "$LIVE_HOME/.local"
  chown_live_path "$LIVE_HOME/Pictures"
  chown_live_path "$LIVE_HOME/.oh-my-zsh"
  chown_live_path "$LIVE_HOME/.zshrc"
}

prepare_runtime() {
  export HOME="$LIVE_HOME"
  export XDG_RUNTIME_DIR="/run/user/$(id -u)"
  export XDG_SESSION_TYPE="wayland"
  export XDG_CURRENT_DESKTOP="Hyprland"
  export MOZ_ENABLE_WAYLAND="1"
  export QT_QPA_PLATFORM="wayland;xcb"
  export WLR_RENDERER_ALLOW_SOFTWARE="1"
  export LIBGL_ALWAYS_SOFTWARE="1"
  export GSK_RENDERER="cairo"
  export WLR_NO_HARDWARE_CURSORS="1"

  install -dm700 "$XDG_RUNTIME_DIR"
}

main() {
  if grep -qw archcfg_nowayland /proc/cmdline; then
    log_info "Skipping Wayland live session because archcfg_nowayland is set"
    return 0
  fi

  if [[ ! -d "$REPO_DIR" ]]; then
    log_warn "Repository not found: $REPO_DIR"
    return 1
  fi

  if ! command -v Hyprland >/dev/null 2>&1; then
    log_warn "Hyprland is not installed in this live environment"
    return 1
  fi

  install_live_configs
  prepare_runtime

  log_info "Starting Hyprland live session"
  if command -v dbus-run-session >/dev/null 2>&1; then
    exec dbus-run-session Hyprland
  fi

  exec Hyprland
}

main "$@"
